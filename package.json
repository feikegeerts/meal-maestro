  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "NODE_ENV=test vitest run --reporter=verbose",
    "test:integration": "vitest run --config=vitest.integration.config.ts",
    "verify": "pnpm run type-check && pnpm run lint && pnpm run test:ci && pnpm run test:integration",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e .env.production.local -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "test:integration:cov": "vitest run --config=vitest.integration.config.ts --coverage"
  },

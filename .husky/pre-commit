#!/bin/sh
set -euo pipefail

resolve_pnpm() {
  PNPM_TOOL_DIR="$HOME/Library/pnpm/.tools/pnpm"
  if [ -d "$PNPM_TOOL_DIR" ]; then
    PNPM_VERSION="$(ls -1 "$PNPM_TOOL_DIR" | head -n1)"
    if [ -n "$PNPM_VERSION" ] && [ -x "$PNPM_TOOL_DIR/$PNPM_VERSION/bin/pnpm" ]; then
      printf "%s\n" "$PNPM_TOOL_DIR/$PNPM_VERSION/bin/pnpm"
      return
    fi
  fi

  if [ -x "./node_modules/.bin/pnpm" ]; then
    printf "%s\n" "./node_modules/.bin/pnpm"
    return
  fi

  if command -v pnpm >/dev/null 2>&1; then
    command -v pnpm
    return
  fi

  return 1
}

PNPM_BIN="$(resolve_pnpm || true)"

if [ -z "${PNPM_BIN}" ]; then
  cat >&2 <<'EOF'
husky (pre-commit): pnpm command not found.
Install pnpm globally (e.g. via "corepack enable pnpm") or add it to devDependencies so node_modules/.bin/pnpm exists.
Skipping automated verify step.
EOF
  exit 0
fi

if ! command -v node >/dev/null 2>&1; then
  if [ -s "$HOME/.nvm/nvm.sh" ]; then
    # shellcheck source=/dev/null
    . "$HOME/.nvm/nvm.sh"
    if command -v nvm >/dev/null 2>&1; then
      nvm use --silent >/dev/null 2>&1 || nvm use default --silent >/dev/null 2>&1 || true
    fi
  elif [ -s "$HOME/.asdf/asdf.sh" ]; then
    # shellcheck source=/dev/null
    . "$HOME/.asdf/asdf.sh"
  fi
fi

if ! command -v node >/dev/null 2>&1; then
  cat >&2 <<'EOF'
husky (pre-commit): node command not found in PATH, cannot execute pnpm.
Ensure Node.js is installed and available before committing.
Skipping automated verify step.
EOF
  exit 0
fi

echo "husky (pre-commit): using pnpm at ${PNPM_BIN}"

if ! "${PNPM_BIN}" verify; then
  status=$?
  cat >&2 <<'EOF'
husky (pre-commit): pnpm verify failed. Commit aborted.
Resolve the issue above or run `pnpm verify` manually to inspect the failure.
EOF
  exit $status
fi
